# LeanMe site — environment variables (copy to .env.local)

NEXT_PUBLIC_SITE_URL=https://demo.leanme.it

# LeanYou (area riservata clienti)
LEANYOU_SESSION_SECRET=change-me-to-a-long-random-string
LEANYOU_DATA_DIR=.leanyou-data
LEANYOU_TENANTS_FILE=.leanyou-data/tenants.json
# Produzione Vercel: sync automatico con npm run leanyou:sync-vercel (dopo vercel link)
# Fallback manuale: npm run leanyou:vercel-env → incolla in Vercel → LEANYOU_TENANTS_JSON
# LEANYOU_TENANTS_JSON={"tenants":[...]}

# OpenAI — required for Leonardo Secretary Assistant processing
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_STRUCTURING_MODEL=gpt-4.1-mini

# Vercel Blob — workspace LeanYou persistenti in produzione (auto se colleghi Blob Store)
# BLOB_READ_WRITE_TOKEN=
