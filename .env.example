# LeanMe site — environment variables (copy to .env.local)

NEXT_PUBLIC_SITE_URL=https://demo.leanme.it

# Teresa pubblica (chat nativa Lean.Agent — solo sito pubblico)
OPENAI_API_KEY=
OPENAI_TERESA_MODEL=gpt-4.1-mini

# Notifiche email SOLO per Teresa pubblica (non lean-event / tenant)
RESEND_API_KEY=
TERESA_NOTIFY_TO=info@leanme.it
# Finché il dominio non è verificato su Resend puoi usare:
# TERESA_NOTIFY_FROM=LeanMe Teresa <onboarding@resend.dev>
TERESA_NOTIFY_FROM=

# Supervisione /lean-human (operatori LeanMe)
LEAN_HUMAN_PASSWORD=
LEAN_HUMAN_SESSION_SECRET=
